# Moving preview tag. Use vX.Y.Z for pinned releases once service images are released.
CRUX_VERSION=main

# Host ports exposed by Docker Compose.
CRUX_SERVER_PORT=7700
CRUX_GATEWAY_PORT=7701
CRUX_MCP_GATEWAY_PORT=7702
CRUX_CONSOLE_PORT=7780

# Postgres backing store for the self-hosted control plane.
POSTGRES_DB=crux
POSTGRES_USER=crux
POSTGRES_PASSWORD=changeme

# Worker execution capacity. Higher values increase parallelism and local resource use.
CRUX_WORKER_ID=selfhosted-worker-1
CRUX_WORKER_CONCURRENCY=2

# Provider credentials are consumed by gateway implementations once they land.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=

# MCP gateway auth and governance settings. Replace change-me before exposing the gateway.
CRUX_MCP_GATEWAY_API_KEYS=change-me,selfhosted-admin,selfhosted,admin,codex
CRUX_MCP_GATEWAY_DEFAULT_POLICY_EFFECT=deny
CRUX_MCP_GATEWAY_BOOTSTRAP_ALLOW_TOOLS=
CRUX_MCP_GATEWAY_DEFAULT_ADAPTER_ID=echo
CRUX_MCP_GATEWAY_ALLOW_SHELL_ADAPTER=false
CRUX_MCP_GATEWAY_AUDIT_SIGNING_KEY=
CRUX_MCP_GATEWAY_REQUIRE_AUDIT_SIGNATURE=false
CRUX_MCP_GATEWAY_DEFAULT_WORKSPACE_BUDGET_USD=100
CRUX_MCP_GATEWAY_COST_PER_1K_TOKENS_USD=0.001
CRUX_MCP_GATEWAY_CONTEXT_BUDGET_BYTES=65536
CRUX_MCP_GATEWAY_PROMPT_INJECTION_PHRASES="ignore previous instructions,reveal system prompt,exfiltrate"
CRUX_MCP_GATEWAY_REPLAY_DRY_RUN_ONLY=true

# Optional console/auth settings reserved for implementation.
CRUX_CONSOLE_AUTH_MODE=none
