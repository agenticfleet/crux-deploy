# Moving preview tag. Use vX.Y.Z for pinned releases once service images are released.
CRUX_VERSION=main

# Host ports exposed by Docker Compose.
CRUX_SERVER_PORT=7700
CRUX_GATEWAY_PORT=7701
CRUX_MCP_GATEWAY_PORT=7702
CRUX_CONSOLE_PORT=7780

# Postgres backing store for the self-hosted control plane.
POSTGRES_DB=crux
POSTGRES_USER=crux
POSTGRES_PASSWORD=changeme

# Worker execution capacity. Higher values increase parallelism and local resource use.
CRUX_WORKER_ID=selfhosted-worker-1
CRUX_WORKER_CONCURRENCY=2

# Provider credentials are consumed by gateway implementations once they land.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=

# Optional console/auth settings reserved for implementation.
CRUX_CONSOLE_AUTH_MODE=none
