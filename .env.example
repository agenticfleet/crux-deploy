# Crux Control V0.1 deployment — .env template
# Copy to .env, set values, then: docker compose --env-file .env up -d

# Image version (use vX.Y.Z for releases; "main" for snapshot)
CRUX_VERSION=main

# Pinned agentgateway version. Must match crux-server's PinnedVersion constant.
# "latest" resolves to sha256:5f66ed5e05c1d51f007448195d939f9adb2bb4ddd70c0a415af38d4a498066a1 (v0.12.0).
# See crux-server/internal/agentgateway/version.go for the validated digest.
AGENTGATEWAY_VERSION=latest
# Log verbosity for agentgateway. Use "debug" to trace MCP routing decisions.
AGENTGATEWAY_LOG_LEVEL=info
# Host port mapped to agentgateway's admin API (crux-server pushes config here).
# agentgateway v0.12.0 admin listens on :15000 (ADMIN_ADDR env); mapped to host here.
AGENTGATEWAY_ADMIN_PORT=8180
# Host port mapped to agentgateway's MCP listener (wedge target URL for managed agents).
AGENTGATEWAY_LISTENER_PORT=7702

# crux-mcp-injection-shim (contingent; only activate if agentgateway cannot host
# the V0.1 wedge demo end-to-end). Run with: COMPOSE_PROFILES=shim docker compose up
CRUX_REQUIRE_SHIM=false
# Host port for the shim's MCP listener. Must match AGENTGATEWAY_LISTENER_PORT
# when shim is active (shim claims 7702 instead of agentgateway).
CRUX_MCP_INJECTION_SHIM_PORT=7702

# Postgres backing store for crux-server.
POSTGRES_DB=crux
POSTGRES_USER=crux
# IMPORTANT: change before exposing to a network.
POSTGRES_PASSWORD=changeme

# crux-server control plane.
# CRUX_SERVER_HOST_PORT: host-side port mapping (change to avoid conflicts with other services).
# crux-server always listens on container-internal port 7700; other containers use that port.
CRUX_SERVER_HOST_PORT=7700
CRUX_SERVER_LISTEN_ADDR=0.0.0.0
# IMPORTANT: set a strong random value before exposing to a network.
CRUX_SERVER_API_KEY=change-me-please

# crux-worker execution engine. Higher concurrency = more parallel agent runs.
# Keep at or below available CPU cores for local installs.
CRUX_WORKER_ID=selfhosted-worker-1
CRUX_WORKER_CONCURRENCY=2

# crux-console read-only operator UI.
# CRUX_CONSOLE_HOST_PORT: host-side port mapping; container always listens on 7780.
CRUX_CONSOLE_HOST_PORT=7780
CRUX_CONSOLE_AUTH_MODE=none

# crux-gateway model gateway (V0.2+; not used in V0.1 wedge demo).
# Uncomment and set API keys when crux-gateway is enabled.
# CRUX_GATEWAY_PORT=7701
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# GOOGLE_API_KEY=
